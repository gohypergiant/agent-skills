{
  "suiteName": "Comprehensive Action And Assertion Coverage",
  "tags": ["@comprehensive-test", "@automation-ready"],
  "source": {
    "repo": "agent-skills",
    "path": "skills/accelint-ac-to-playwright/assets/evals/PERFECT-AC.feature"
  },
  "tests": [
    {
      "testName": "multiple visibility state changes",
      "tags": ["@visibility-changes", "@smoke"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "click",
          "target": "page.button.toggle-interface"
        },
        {
          "type": "expectNotVisible",
          "target": "drawer.div.settings-panel"
        },
        {
          "type": "expectVisible",
          "target": "drawer.div.settings-panel"
        },
        {
          "type": "expectNotVisible",
          "target": "modal.text.welcome"
        },
        {
          "type": "expectVisible",
          "target": "modal.text.welcome"
        },
        {
          "type": "expectVisible",
          "target": "card.text.tutorial"
        },
        {
          "type": "expectNotVisible",
          "target": "card.text.tutorial"
        }
      ]
    },
    {
      "testName": "keyboard modifier combination",
      "tags": ["@keyboard-modifier-combo"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "keyDown",
          "key": "Shift"
        },
        {
          "type": "press",
          "key": "e"
        },
        {
          "type": "keyUp",
          "key": "Shift"
        },
        {
          "type": "expectText",
          "target": "header.text.banner",
          "text": "Edit mode activated"
        }
      ]
    },
    {
      "testName": "keyboard hold and release sequence",
      "tags": ["@keyboard-hold-sequence"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "keyDown",
          "key": "Shift"
        },
        {
          "type": "click",
          "target": "page.button.item"
        },
        {
          "type": "keyUp",
          "key": "Shift"
        },
        {
          "type": "expectText",
          "target": "page.text.selection",
          "text": "Multi-select enabled"
        }
      ]
    },
    {
      "testName": "element-based actions and basic assertions",
      "tags": ["@basic-interactions", "@smoke"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "click",
          "target": "form.button.login"
        },
        {
          "type": "fill",
          "target": "form.input.email",
          "value": "test@example.com"
        },
        {
          "type": "fill",
          "target": "form.input.password",
          "value": "secure123"
        },
        {
          "type": "select",
          "target": "form.dropdown.plan",
          "value": "Premium Plan"
        },
        {
          "type": "press",
          "key": "Enter"
        },
        {
          "type": "expectUrl",
          "url": "/success"
        },
        {
          "type": "expectText",
          "target": "page.text.success",
          "text": "Submitted successfully"
        }
      ]
    },
    {
      "testName": "mouse drag operation",
      "tags": ["@mouse-drag"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "drag",
          "startX": 100,
          "startY": 100,
          "endX": 300,
          "endY": 300
        },
        {
          "type": "expectText",
          "target": "toast.text.success",
          "text": "Zoom area has been set"
        }
      ]
    },
    {
      "testName": "mouse position, press, and release sequence",
      "tags": ["@mouse-click-sequence"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "mouseMove",
          "x": 150,
          "y": 200
        },
        {
          "type": "mouseDown",
          "button": "left"
        },
        {
          "type": "press",
          "key": "p"
        },
        {
          "type": "mouseUp",
          "button": "left"
        },
        {
          "type": "expectText",
          "target": "toast.text.success",
          "text": "Point marked"
        }
      ]
    },
    {
      "testName": "coordinate-based double-click",
      "tags": ["@mouse-single-and-double-click"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "mouseClick",
          "x": 250,
          "y": 50,
          "button": "left"
        },
        {
          "type": "doubleClick",
          "x": 250,
          "y": 100,
          "button": "left"
        },
        {
          "type": "expectText",
          "target": "modal.text.distance",
          "text": "Distance between these points is 50"
        }
      ]
    },
    {
      "testName": "user scrolls on the page",
      "tags": ["@scrolling"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "scroll",
          "direction": "down",
          "amount": 200
        },
        {
          "type": "scroll",
          "direction": "right",
          "amount": 75
        },
        {
          "type": "expectText",
          "target": "page.text.position",
          "text": "You scrolled to the southeast"
        }
      ]
    },
    {
      "testName": "page reload action",
      "tags": ["@page-reload"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "click",
          "target": "nav.link.refresh"
        },
        {
          "type": "reload"
        },
        {
          "type": "expectText",
          "target": "header.text.status",
          "text": "Page refreshed"
        }
      ]
    },
    {
      "testName": "hover interaction",
      "tags": ["@hover-action"],
      "startUrl": "/test",
      "steps": [
        {
          "type": "hover",
          "target": "card.button.info"
        },
        {
          "type": "expectText",
          "target": "card.text.tooltip",
          "text": "Additional information"
        }
      ]
    }
  ]
}
