# Copy to .env and fill in. Referenced by conftest fixtures — the default
# offline run (regression tests, rubric self-checks) needs NONE of these.

# Judge (grades the SUT's output) — request a personal virtual key.
LITELLM_BASE_URL=https://litellm-ai.accelint.dev
LITELLM_API_KEY=sk-REPLACE_ME
JUDGE_MODEL_ALIAS=bedrock-claude-4-5-sonnet

# SUT (the model being graded). SUT_PROVIDER: "litellm" or "anthropic".
SUT_PROVIDER=litellm
SUT_MODEL_ID=bedrock-claude-4-5-sonnet
SUT_LITELLM_BASE_URL=https://litellm-ai.accelint.dev
# litellm provider reuses LITELLM_API_KEY above; the anthropic provider needs:
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
