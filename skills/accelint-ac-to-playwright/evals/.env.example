# ---------------------------------------------------------------------------
# Eval harness environment variables — copy to .env and fill in your values.
# NEVER commit the filled-in .env file; .gitignore already excludes it.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Judge configuration (LiteLLM proxy used by DeepEval GEval metrics)
# ---------------------------------------------------------------------------

# URL of the LiteLLM proxy that routes judge requests.
# Example: http://localhost:4000  or  https://litellm.internal.example.com
LITELLM_BASE_URL=http://your-litellm-proxy:4000

# Virtual key issued by the proxy.  Request a personal key from your team
# admin — NEVER reuse the CI key in a local .env.  The CI key is rotated on
# every release and its compromise would block all automated eval runs.
LITELLM_API_KEY=sk-your-personal-virtual-key

# Model alias registered on the LiteLLM proxy to use as the LLM judge.
# The alias is prefixed with "openai/" internally (see litellm_judge.py).
# Example: bedrock-claude-4-5-sonnet  or  gpt-4o-judge
JUDGE_MODEL_ALIAS=bedrock-claude-4-5-sonnet

# ---------------------------------------------------------------------------
# SUT (System Under Test) configuration
# ---------------------------------------------------------------------------

# Which provider adapter the SUT runner should use.
# Supported values: litellm, anthropic
SUT_PROVIDER=litellm

# Model identifier passed to the provider.
# For litellm: the model alias registered on the proxy.
# For anthropic: the Anthropic model ID (e.g. claude-opus-4-5-20251101).
SUT_MODEL_ID=claude-opus-4-5-20251101

# Base URL of the LiteLLM proxy for SUT requests.
# Only required when SUT_PROVIDER=litellm.
# Can point to the same proxy as the judge or a separate one.
SUT_LITELLM_BASE_URL=http://your-litellm-proxy:4000
