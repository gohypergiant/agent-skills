# Judge (DeepEval) — request a personal virtual key; do not reuse the CI key.
LITELLM_BASE_URL=https://litellm-ai.accelint.dev
LITELLM_API_KEY=sk-REPLACE_ME
JUDGE_MODEL_ALIAS=bedrock-claude-4-5-sonnet

# SUT (the model being graded)
# NOTE: runner.py reuses LITELLM_API_KEY above for the SUT proxy call — set it
# even for judge-free runs that invoke the SUT.
SUT_MODEL_ID=bedrock-claude-4-5-sonnet
SUT_LITELLM_BASE_URL=https://litellm-ai.accelint.dev
