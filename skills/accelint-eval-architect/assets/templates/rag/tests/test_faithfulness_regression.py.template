"""Regression: the faithfulness GATE can fail (offline, stubbed judge).

Stubs the ragas modules so this runs in the default free suite. It proves the
metric's gating logic — threshold comparison and reason — fails when the judge
scores low, satisfying "every metric needs a regression test that proves it
can fail". It does NOT validate Ragas itself; that is the gated live test's
job once a real threshold is calibrated.
"""

import sys
import types


def test_faithfulness_gate_fails_on_low_judge_score(monkeypatch):
    fake_ragas = types.ModuleType("ragas")
    fake_metrics = types.ModuleType("ragas.metrics")

    class FakeSample:
        def __init__(self, **kwargs):
            self.kwargs = kwargs

    class FakeFaithfulness:
        def __init__(self, llm=None):
            self.llm = llm

        def single_turn_score(self, sample):
            return 0.2  # planted: judge says the answer is NOT grounded

    fake_ragas.SingleTurnSample = FakeSample
    fake_metrics.Faithfulness = FakeFaithfulness
    monkeypatch.setitem(sys.modules, "ragas", fake_ragas)
    monkeypatch.setitem(sys.modules, "ragas.metrics", fake_metrics)

    from metrics.faithfulness_ragas import FaithfulnessMetric

    metric = FaithfulnessMetric(judge_model=None, threshold=0.7)  # calibrated gate
    score = metric.measure("q", "an answer the judge rejects", ["some context"])

    assert score == 0.2
    assert not metric.is_successful(), "gate must fail when the judge scores below threshold"
    assert "0.2" in metric.reason
