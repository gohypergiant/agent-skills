"""Generate metric: faithfulness (answer grounded in retrieved context).

GATED — uses a judge LLM via Ragas. Lazily imports ragas so the deterministic
(offline) test run never needs it installed. Swap to a DeepEval GEval metric here
if your answer rubric is bespoke (see references/frameworks/ragas.md).

Threshold ships RECORD-ONLY (0.0): faithfulness is judge-scored and noisy —
calibrate from a baseline before gating on it (references/calibration.md).
"""

from typing import Optional


class FaithfulnessMetric:
    def __init__(self, judge_model=None, embeddings=None, threshold: float = 0.0):
        # threshold 0.0 = record-only until calibrated
        self.judge_model = judge_model
        self.embeddings = embeddings
        self.threshold = threshold
        self.score = 0.0
        self.success = False
        self.reason: Optional[str] = None

    def measure(self, question: str, answer: str, retrieved_contexts: list[str]) -> float:
        # Lazy import: keeps `uv run pytest` (deterministic) free of a ragas dep.
        from ragas import evaluate
        from ragas.metrics import faithfulness
        from datasets import Dataset

        ds = Dataset.from_dict({
            "question": [question],
            "answer": [answer],
            "contexts": [retrieved_contexts],
        })
        result = evaluate(
            ds,
            metrics=[faithfulness],
            llm=self.judge_model,         # wire your proxy-backed judge (see ragas.md)
            embeddings=self.embeddings,
        )
        self.score = float(result["faithfulness"])
        self.success = self.score >= self.threshold
        self.reason = f"faithfulness={self.score:.2f} (record-only until calibrated)"
        return self.score

    def is_successful(self) -> bool:
        return self.success

    @property
    def __name__(self):
        return "Faithfulness"
