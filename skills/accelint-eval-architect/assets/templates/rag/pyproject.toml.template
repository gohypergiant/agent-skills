[project]
name = "__TARGET_NAME__-evals"
version = "1.0.0"
description = "RAG eval harness for __TARGET_NAME__ (internal-only)"
requires-python = ">=3.11"
# Floors, not hard pins: hard pins rot. Commit the uv.lock for reproducibility.
dependencies = [
    "pytest>=8.3",
    "pyyaml>=6.0",
    "python-dotenv>=1.0.1",
    # Judge layer (only needed for `-m live`):
    "ragas>=0.2",
    "langchain-openai>=0.2",  # LangchainLLMWrapper judge wiring (ragas.md)
    # litellm is NOT needed here: the judge talks to a remote LiteLLM proxy via
    # langchain-openai. Add it only if your runner.py adapters import it.
]

[tool.pytest.ini_options]
# Deterministic ingest + retrieve run by default; the Ragas faithfulness metric
# is opt-in via `-m live`.
addopts = ["-ra", "--tb=short", "-p", "no:cacheprovider", "-m", "not live"]
